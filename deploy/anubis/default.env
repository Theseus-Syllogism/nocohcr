# ---- Anubis instance: default (systemd: anubis@default) ----
# Listener Anubis exposes to nginx (loopback only; nginx is the TLS edge)
BIND=127.0.0.1:8923
BIND_NETWORK=tcp
# Prometheus metrics (loopback only)
METRICS_BIND=127.0.0.1:9090
METRICS_BIND_NETWORK=tcp
# Bot policy (PoW + fingerprint rules). (data)/ imports resolve from the binary.
POLICY_FNAME=/etc/anubis/botPolicies.yaml
# Proof-of-work difficulty (leading zero nibbles). 4 = default.
DIFFICULTY=4
# Let Anubis serve its own robots.txt for protected routes
SERVE_ROBOTS_TXT=1
# Persistent signing key (keeps challenge cookies valid across restarts). KEEP SECRET.
ED25519_PRIVATE_KEY_HEX=CHANGE_ME_64_HEX_CHARS
# Trust the X-Forwarded-For nginx sets (nginx is the only thing in front).
# >>> SET THIS to your real backend application <<<
TARGET=http://127.0.0.1:3000
